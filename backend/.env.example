# ─────────────────────────────────────────────────────────────────────────────
# ExitLens Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=4000
BASE_URL=http://localhost:4000

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/exitlens
# For Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/exitlens?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_STRING
JWT_EXPIRES_IN=7d
JWT_COOKIE_MAX_AGE_MS=604800000    # 7 days in ms

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000,https://app.yourdomain.com

# ── AI Provider ───────────────────────────────────────────────────────────────
AI_PROVIDER=gemini              # gemini | openai
GEMINI_API_KEY=REPLACE_WITH_GEMINI_KEY
OPENAI_API_KEY=REPLACE_WITH_OPENAI_KEY

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH_MAX=5           # auth endpoints (per 15 min)
RATE_LIMIT_TRACK_MAX=200        # tracking endpoint (per 1 min)
RATE_LIMIT_API_MAX=100          # general API (per 15 min)

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info                  # error | warn | info | debug
LOG_DIR=./logs

# ── Frontend URL (for cookie domain in prod) ──────────────────────────────────
FRONTEND_URL=http://localhost:3000
